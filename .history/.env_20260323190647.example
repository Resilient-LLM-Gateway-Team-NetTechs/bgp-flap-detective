# Copy this file to .env and replace placeholders.

BFD_DEFAULT_USERNAME=admin
BFD_DEFAULT_PASSWORD=admin
BFD_DEFAULT_DEVICE_TYPE=cisco_nxos
BFD_DEFAULT_PORT=22

# Optional JSON file path for inventory loading.
# If unset, in-code defaults are used.
BFD_INVENTORY_FILE=

# Set to 1 to run with synthetic command outputs and no SSH dependency.
BFD_MOCK_MODE=0
